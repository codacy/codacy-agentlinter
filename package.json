{
  "name": "codacy-agentlinter",
  "description": "Agentlinter Tool for Codacy",
  "keywords": [
    "codacy",
    "agentlinter",
    "agent",
    "linter",
    "typescript"
  ],
  "homepage": "https://github.com/codacy/codacy-agentlinter#readme",
  "bugs": {
    "url": "https://github.com/codacy/codacy-agentlinter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codacy/codacy-agentlinter.git"
  },
  "license": "Apache-2.0",
  "main": "dist/src/index.js",
  "directories": {
    "test": "./src/test",
    "src": "./src"
  },
  "scripts": {
    "build": "tsc --showConfig && tsc",
    "build:docker": "npm run build && docker build -t codacy-agentlinter .",
    "build:docs": "npm run build && node dist/src/docGenerator.js",
    "lint": "eslint --fix --ext .ts ./src",
    "test": "mocha"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "package.json": [
      "sort-package-json",
      "git add"
    ],
    "src/*.{ts,js,css,json,md}": [
      "git add"
    ]
  },
  "prettier": {
    "semi": false
  },
  "mocha": {
    "extension": [
      "ts"
    ],
    "require": "ts-node/register",
    "spec": "src/test/**/*.spec.ts"
  },
  "dependencies": {
    "agentlinter": ">=0.3.3",
    "codacy-seed": "^2.2.2",
    "glob": "^10.3.10",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "axios": "^1.12.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2"
  }
}
